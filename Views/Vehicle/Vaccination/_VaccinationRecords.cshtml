@using CarCareTracker.Helper
@inject IConfigHelper config
@model List<VaccinationRecord>
@{
    var userConfig = config.GetUserConfig(User);
    var recordTags = Model.SelectMany(x => x.Tags).Distinct();
}
<div class="d-flex flex-column vehicleTabPane">
<div class="row">
    <div class="d-flex justify-content-between">
        <div class="d-flex align-items-center flex-wrap gap-2">
            <span class="badge bg-success" data-aggregate-type="count">@($"# of Vaccinations: {Model.Count()}")</span>
            <span class="badge bg-primary" data-aggregate-type="sum">@($"Total: {Model.Sum(x => x.Cost).ToString("C")}")</span>
            @foreach (string recordTag in recordTags)
            {
                <span onclick="filterTable('vaccination-tab-pane', this)" class="user-select-none rounded-pill badge bg-secondary tagfilter" style="cursor:pointer;">@recordTag</span>
            }
            <datalist id="vaccinationTagList">
                @foreach (string recordTag in recordTags)
                {
                    <!option value="@recordTag"></!option>
                }
            </datalist>
        </div>
        <div class="lubelogger-record-add">
            <div class="btn-group">
                <button onclick="showAddVaccinationRecordModal()" class="btn btn-primary btn-md mt-1 mb-1"><i class="bi bi-shield-plus me-2"></i>Add Vaccination</button>
                <button type="button" class="btn btn-md btn-primary btn-md mt-1 mb-1 dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="visually-hidden">Toggle Dropdown</span>
                </button>
                <ul class="dropdown-menu record-dropdown">
                    <li><a class="dropdown-item" href="#" onclick="printTab()">Print</a></li>
                    <li><a class="dropdown-item" href="#" onclick="searchTableRows('vaccination-tab-pane')">Search</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>
<div class="row vehicleDetailTabContainer flex-grow-1">
    <div class="col-12">
        @if (Model.Any())
        {
        <table class="table table-hover">
            <thead class="sticky-top">
                <tr class="d-flex">
                    <th scope="col" class="col-2 flex-grow-1 text-truncate">Date</th>
                    <th scope="col" class="col-3 text-truncate">Vaccine</th>
                    <th scope="col" class="col-2 text-truncate d-none d-md-table-cell">Clinic</th>
                    <th scope="col" class="col-2 text-truncate d-none d-md-table-cell">Next Due</th>
                    <th scope="col" class="col-1 text-truncate d-none d-sm-table-cell">Cost</th>
                    <th scope="col" class="col-1 text-truncate d-none d-lg-table-cell">Reminder</th>
                </tr>
            </thead>
            <tbody>
                @foreach (VaccinationRecord record in Model)
                {
                    <tr class="d-flex user-select-none" style="cursor:pointer;"
                        data-rowId="@record.Id"
                        data-tags='@string.Join(" ", record.Tags)'
                        onclick="handleTableRowClick(this, showEditVaccinationRecordModal, @record.Id)">
                        <td class="col-2 flex-grow-1 text-truncate">@record.Date.ToShortDateString()</td>
                        <td class="col-3 text-truncate">
                            @record.VaccineName
                            @if (!string.IsNullOrWhiteSpace(record.Notes))
                            {
                                <i class="bi bi-chat-text ms-1 text-muted" title="Has notes"></i>
                            }
                            @if (record.Files.Any())
                            {
                                <i class="bi bi-paperclip ms-1 text-muted" title="Has attachments"></i>
                            }
                        </td>
                        <td class="col-2 text-truncate d-none d-md-table-cell">@record.Clinic</td>
                        <td class="col-2 text-truncate d-none d-md-table-cell">
                            @if (!string.IsNullOrWhiteSpace(record.NextDueDate))
                            {
                                <span class="badge bg-warning text-dark">@record.NextDueDate</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="col-1 text-truncate d-none d-sm-table-cell">@(record.Cost == 0 ? "-" : record.Cost.ToString("C"))</td>
                        <td class="col-1 text-truncate d-none d-lg-table-cell">
                            @if (record.ReminderEnabled)
                            {
                                <i class="bi bi-bell-fill text-primary" title="Reminder enabled"></i>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        }
        else
        {
            <div class="d-flex justify-content-center align-items-center mt-4">
                <div class="text-center text-muted">
                    <i class="bi bi-shield-plus display-4"></i>
                    <p class="mt-2">No vaccination records yet. Add the first one!</p>
                    <button onclick="showAddVaccinationRecordModal()" class="btn btn-outline-primary"><i class="bi bi-plus-lg me-2"></i>Add Vaccination</button>
                </div>
            </div>
        }
    </div>
</div>
</div>

<div class="modal fade" data-bs-focus="false" id="vaccinationRecordModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="vaccinationRecordModalContent">
        </div>
    </div>
</div>
