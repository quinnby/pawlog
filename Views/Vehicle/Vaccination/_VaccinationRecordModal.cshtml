@using CarCareTracker.Helper
@inject IConfigHelper config
@model VaccinationRecordInput
@{
    var isNew = Model.Id == 0;
    var userConfig = config.GetUserConfig(User);
}
<div class="modal-header">
    <h5 class="modal-title">@(isNew ? "Add Vaccination Record" : "Edit Vaccination Record")</h5>
    <button type="button" class="btn-close" onclick="hideAddVaccinationRecordModal()" aria-label="Close"></button>
</div>
<div class="modal-body" onkeydown="handleEnter(this)">
    <form>
        <div class="form-group">
            <div class="row">
                <!-- LEFT COLUMN -->
                <div class="col-md-6 col-12">
                    <input type="text" id="workAroundInput" style="height:0px; width:0px; display:none;">

                    <label for="vaccinationDate">Date Administered</label>
                    <div class="input-group">
                        <input type="text" id="vaccinationDate" class="form-control" placeholder="Date administered" value="@Model.Date">
                        <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                    </div>

                    <label for="vaccinationName" class="mt-2">Vaccine Name</label>
                    <input type="text" id="vaccinationName" class="form-control" placeholder="e.g. Rabies, DHPP, Bordetella" value="@Model.VaccineName">

                    <label for="vaccinationNextDueDate" class="mt-2">Next Due Date (optional)</label>
                    <div class="input-group">
                        <input type="text" id="vaccinationNextDueDate" class="form-control" placeholder="Next booster due date" value="@Model.NextDueDate">
                        <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                    </div>

                    <label for="vaccinationLotNumber" class="mt-2">Lot / Batch Number (optional)</label>
                    <input type="text" id="vaccinationLotNumber" class="form-control" placeholder="Vaccine lot or batch number" value="@Model.LotNumber">

                    <label for="vaccinationAdministeredBy" class="mt-2">Administered By (optional)</label>
                    <input type="text" id="vaccinationAdministeredBy" class="form-control" placeholder="Veterinarian or technician name" value="@Model.AdministeredBy">

                    <label for="vaccinationClinic" class="mt-2">Clinic (optional)</label>
                    <input type="text" id="vaccinationClinic" class="form-control" placeholder="Clinic or practice name" value="@Model.Clinic">

                    <label for="vaccinationCost" class="mt-2">Cost (optional)</label>
                    <input type="text" inputmode="decimal" onkeydown="interceptDecimalKeys(event)" onkeyup="fixDecimalInput(this, 2)"
                           id="vaccinationCost" class="form-control" placeholder="0.00" value="@(isNew ? "" : Model.Cost)">

                    <label for="vaccinationTag" class="mt-2">Tags (optional)</label>
                    <select multiple class="form-select" id="vaccinationTag">
                        @foreach (string tag in Model.Tags)
                        {
                            <option value="@tag">@tag</option>
                        }
                    </select>

                    @await Html.PartialAsync("_ExtraField", Model.ExtraFields)
                </div>

                <!-- RIGHT COLUMN -->
                <div class="col-md-6 col-12">
                    <div class="form-check mt-2 mt-md-0">
                        <input class="form-check-input" type="checkbox" id="vaccinationReminderEnabled" @(Model.ReminderEnabled ? "checked" : "")>
                        <label class="form-check-label" for="vaccinationReminderEnabled">
                            Enable Renewal Reminder
                            <small class="text-muted d-block">A reminder hook will be stored when Next Due Date is set. Full reminder engine wiring is planned for a later phase.</small>
                        </label>
                    </div>

                    <label for="vaccinationNotes" class="mt-2">Notes (optional)<a class="link-underline link-underline-opacity-0" onclick="showLinks(this)"><i class="bi bi-markdown ms-2"></i></a></label>
                    <textarea id="vaccinationNotes" class="form-control" rows="5">@Model.Notes</textarea>

                    <div class="mt-2">
                        @await Html.PartialAsync("_UploadedFiles", Model.Files)
                        @await Html.PartialAsync("_FileUploader", Model.Files.Any())
                    </div>
                    <div id="filesPendingUpload"></div>
                </div>
            </div>
        </div>
    </form>
</div>
<div class="modal-footer">
    @if (!isNew)
    {
        <div class="btn-group" style="margin-right:auto;">
            <button type="button" class="btn btn-md mt-1 mb-1 btn-danger" onclick="deleteVaccinationRecord(@Model.Id)">Delete</button>
        </div>
    }
    <button type="button" class="btn btn-secondary" onclick="hideAddVaccinationRecordModal()">Cancel</button>
    @if (isNew)
    {
        <button type="button" class="btn btn-primary" onclick="saveVaccinationRecordToVehicle()">Add Vaccination</button>
    }
    else
    {
        <button type="button" class="btn btn-primary" onclick="saveVaccinationRecordToVehicle(true)">Save Vaccination</button>
    }
</div>
<script>
    function getVaccinationRecordModelData() {
        return { id: @Model.Id, vehicleId: @Model.VehicleId };
    }
</script>
