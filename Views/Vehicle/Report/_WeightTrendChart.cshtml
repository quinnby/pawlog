@*
  Phase 7 – Weight trend chart modal shell.
  Data is loaded asynchronously via showWeightTrendChart() in healthrecord.js.
  vehicleId is passed to the JS via GetVehicleId().
*@
<div class="modal-header">
    <h5 class="modal-title"><i class="bi bi-graph-up me-2"></i>Weight Trend</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <div id="weightChartPlaceholder" class="d-flex justify-content-center align-items-center py-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
    <div id="weightChartContainer" style="display:none; position:relative; height:300px;">
        <canvas id="weightTrendCanvas"></canvas>
    </div>
    <div id="weightChartEmpty" class="text-center text-muted py-4" style="display:none;">
        <i class="bi bi-graph-up display-5"></i>
        <p class="mt-2">No weight entries with a numeric value yet.<br/>
           Add a <strong>Weight Check</strong> health record and fill in the weight measurement field to start tracking.</p>
    </div>
    <!-- Weight history table -->
    <table id="weightHistoryTable" class="table table-sm mt-3" style="display:none;">
        <thead>
            <tr>
                <th>Date</th>
                <th>Weight</th>
                <th>Entry</th>
            </tr>
        </thead>
        <tbody id="weightHistoryTableBody"></tbody>
    </table>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
</div>
<script>
    (function () {
        var vehicleId = GetVehicleId().vehicleId;
        $.get('/Vehicle/GetWeightHistoryByVehicleId?vehicleId=' + vehicleId, function (data) {
            $('#weightChartPlaceholder').hide();
            if (!data || data.length === 0) {
                $('#weightChartEmpty').show();
                return;
            }
            // Build table
            var tbody = $('#weightHistoryTableBody');
            tbody.empty();
            data.forEach(function (entry) {
                tbody.append('<tr><td>' + entry.date + '</td><td>' + entry.value + ' ' + entry.unit + '</td><td>' + (entry.title || '') + '</td></tr>');
            });
            $('#weightHistoryTable').show();
            // Build chart
            var labels = data.map(function (e) { return e.date; });
            var values = data.map(function (e) { return e.value; });
            // Detect mixed units: if entries use more than one unit, label chart generically
            // and show per-point unit in tooltips. Legacy records without a stored unit
            // have already been normalised to "lbs" by the server-side fallback.
            var allUnits = data.map(function (e) { return e.unit; });
            var distinctUnits = allUnits.filter(function (u, i, a) { return a.indexOf(u) === i; });
            var isMixedUnits = distinctUnits.length > 1;
            var commonUnit   = isMixedUnits ? '' : (distinctUnits[0] || '');
            var datasetLabel = isMixedUnits ? 'Weight' : ('Weight (' + commonUnit + ')');
            var yAxisLabel   = isMixedUnits ? 'Weight (mixed units — see tooltip)' : ('Weight (' + commonUnit + ')');
            var useDarkMode = getGlobalConfig().useDarkMode;
            var lineColor = useDarkMode ? '#4fc3f7' : '#1976d2';
            $('#weightChartContainer').show();
            new Chart($('#weightTrendCanvas'), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: datasetLabel,
                        data: values,
                        borderColor: lineColor,
                        backgroundColor: lineColor + '33',
                        tension: 0.3,
                        fill: true,
                        pointRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: false,
                            title: { display: true, text: yAxisLabel }
                        }
                    },
                    plugins: {
                        legend: { display: true },
                        tooltip: {
                            callbacks: {
                                // Always show per-point unit in tooltip for clarity
                                label: function (context) {
                                    var entry = data[context.dataIndex];
                                    return (entry.title ? entry.title + ': ' : '') + entry.value + ' ' + entry.unit;
                                }
                            }
                        }
                    }
                }
            });
        });
    })();
</script>
