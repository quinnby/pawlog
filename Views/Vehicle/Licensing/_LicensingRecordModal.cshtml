@using CarCareTracker.Helper
@inject IConfigHelper config
@model LicensingRecordInput
@{
    var isNew = Model.Id == 0;
    var userConfig = config.GetUserConfig(User);
}
<div class="modal-header">
    <h5 class="modal-title">@(isNew ? "Add Licensing Record" : "Edit Licensing Record")</h5>
    <button type="button" class="btn-close" onclick="hideAddLicensingRecordModal()" aria-label="Close"></button>
</div>
<div class="modal-body" onkeydown="handleEnter(this)">
    <form>
        <div class="form-group">
            <div class="row">
                <!-- LEFT COLUMN -->
                <div class="col-md-6 col-12">
                    <input type="text" id="workAroundInput" style="height:0px; width:0px; display:none;">

                    <label for="licensingIssueDate">Issue Date</label>
                    <div class="input-group">
                        <input type="text" id="licensingIssueDate" class="form-control" placeholder="Date license was issued" value="@Model.Date">
                        <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                    </div>

                    <label for="licensingNumber" class="mt-2">License Number</label>
                    <input type="text" id="licensingNumber" class="form-control" placeholder="Official license or tag number" value="@Model.LicenseNumber">

                    <label for="licensingIssuer" class="mt-2">Issuer / Municipality (optional)</label>
                    <input type="text" id="licensingIssuer" class="form-control" placeholder="e.g. City of Austin, King County" value="@Model.Issuer">

                    <label for="licensingExpiryDate" class="mt-2">Expiry / Renewal Due Date (optional)</label>
                    <div class="input-group">
                        <input type="text" id="licensingExpiryDate" class="form-control" placeholder="Date license expires" value="@Model.ExpiryDate">
                        <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                    </div>

                    <label for="licensingCost" class="mt-2">Cost (optional)</label>
                    <input type="text" inputmode="decimal" onkeydown="interceptDecimalKeys(event)" onkeyup="fixDecimalInput(this, 2)"
                           id="licensingCost" class="form-control" placeholder="0.00" value="@(isNew ? "" : Model.Cost)">

                    <label for="licensingTag" class="mt-2">Tags (optional)</label>
                    <select multiple class="form-select" id="licensingTag">
                        @foreach (string tag in Model.Tags)
                        {
                            <option value="@tag">@tag</option>
                        }
                    </select>

                    @await Html.PartialAsync("_ExtraField", Model.ExtraFields)
                </div>

                <!-- RIGHT COLUMN -->
                <div class="col-md-6 col-12">
                    <div class="form-check mt-2 mt-md-0">
                        <input class="form-check-input" type="checkbox" id="licensingRenewalReminderEnabled" @(Model.RenewalReminderEnabled ? "checked" : "")>
                        <label class="form-check-label" for="licensingRenewalReminderEnabled">
                            Enable Renewal Reminder
                            <small class="text-muted d-block">Reminder hook stored on Expiry Date. Full wiring planned for a later phase.</small>
                        </label>
                    </div>

                    <label for="licensingNotes" class="mt-2">Notes (optional)<a class="link-underline link-underline-opacity-0" onclick="showLinks(this)"><i class="bi bi-markdown ms-2"></i></a></label>
                    <textarea id="licensingNotes" class="form-control" rows="5">@Model.Notes</textarea>

                    <div class="mt-2">
                        @await Html.PartialAsync("_UploadedFiles", Model.Files)
                        @await Html.PartialAsync("_FileUploader", Model.Files.Any())
                    </div>
                    <div id="filesPendingUpload"></div>
                </div>
            </div>
        </div>
    </form>
</div>
<div class="modal-footer">
    @if (!isNew)
    {
        <div class="btn-group" style="margin-right:auto;">
            <button type="button" class="btn btn-md mt-1 mb-1 btn-danger" onclick="deleteLicensingRecord(@Model.Id)">Delete</button>
        </div>
    }
    <button type="button" class="btn btn-secondary" onclick="hideAddLicensingRecordModal()">Cancel</button>
    @if (isNew)
    {
        <button type="button" class="btn btn-primary" onclick="saveLicensingRecordToVehicle()">Add License</button>
    }
    else
    {
        <button type="button" class="btn btn-primary" onclick="saveLicensingRecordToVehicle(true)">Save License</button>
    }
</div>
<script>
    function getLicensingRecordModelData() {
        return { id: @Model.Id, vehicleId: @Model.VehicleId };
    }
</script>
